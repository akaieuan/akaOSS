{
  "name": "akaoss",
  "version": "0.1.0",
  "private": true,
  "description": "akaOSS — the studio site at akaoss.dev: five open-source projects for human-in-the-loop AI measurement and developer tooling, plus the research feed and the HITL Kit component registry.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "registry:build": "shadcn build",
    "registry:check": "pnpm registry:build && git diff --exit-code public/r registry.json && echo '✓ registry up to date'",
    "verify": "pnpm typecheck && pnpm registry:check && pnpm build",
    "smoke-test": "bash scripts/smoke-test.sh local",
    "smoke-test:prod": "bash scripts/smoke-test.sh prod"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "shadcn": "^4.3.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2",
      "postcss": "^8.5.10",
      "ip-address": "^10.1.1",
      "brace-expansion": "^5.0.6",
      "qs": "^6.15.2"
    }
  }
}
